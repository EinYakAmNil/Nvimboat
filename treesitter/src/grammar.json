{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "nvimboat",
  "rules": {
    "nvimboat": {
      "type": "REPEAT",
      "content": {
        "type": "SYMBOL",
        "name": "_element"
      }
    },
    "_element": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "_filter"
        },
        {
          "type": "SYMBOL",
          "name": "_feed"
        },
        {
          "type": "SYMBOL",
          "name": "_article"
        },
        {
          "type": "SYMBOL",
          "name": "header"
        },
        {
          "type": "SYMBOL",
          "name": "body"
        }
      ]
    },
    "_filter": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "unread_filter"
        },
        {
          "type": "SYMBOL",
          "name": "read_filter"
        }
      ]
    },
    "_feed": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "unread_feed"
        },
        {
          "type": "SYMBOL",
          "name": "read_feed"
        }
      ]
    },
    "_article": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "unread_article"
        },
        {
          "type": "SYMBOL",
          "name": "read_article"
        }
      ]
    },
    "unread_filter": {
      "type": "PATTERN",
      "value": "N \\(\\d+\\/\\d+\\).*? â”‚ query:.*?, tags:.*?"
    },
    "read_filter": {
      "type": "PATTERN",
      "value": "  \\(\\d+\\/\\d+\\).*? â”‚ query:.*?, tags:.*?"
    },
    "unread_feed": {
      "type": "PATTERN",
      "value": "N \\(\\d+\\/\\d+\\).*? â”‚ http.*?"
    },
    "read_feed": {
      "type": "PATTERN",
      "value": "  \\(\\d+\\/\\d+\\).*? â”‚ http.*?"
    },
    "unread_article": {
      "type": "PATTERN",
      "value": "N â”‚ \\d\\d (?:Jan|Feb|Mar|Apr|May|Jun|Jul|Aug|Sep|Oct|Nov|Dec).*?"
    },
    "read_article": {
      "type": "PATTERN",
      "value": "  â”‚ \\d\\d (?:Jan|Feb|Mar|Apr|May|Jun|Jul|Aug|Sep|Oct|Nov|Dec).*?"
    },
    "header": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "_header_line"
        }
      ]
    },
    "_header_line": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "_header_key"
        },
        {
          "type": "STRING",
          "value": ":"
        },
        {
          "type": "SYMBOL",
          "name": "_expression"
        }
      ]
    },
    "_header_key": {
      "type": "CHOICE",
      "members": [
        {
          "type": "STRING",
          "value": "Feed"
        },
        {
          "type": "STRING",
          "value": "Title"
        },
        {
          "type": "STRING",
          "value": "Author"
        },
        {
          "type": "STRING",
          "value": "Date"
        },
        {
          "type": "STRING",
          "value": "Link"
        }
      ]
    },
    "body": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "body_start"
        },
        {
          "type": "SYMBOL",
          "name": "content"
        }
      ]
    },
    "body_start": {
      "type": "PATTERN",
      "value": "== Article Begin =="
    },
    "content": {
      "type": "PATTERN",
      "value": "(.*?\\n)+?"
    },
    "_expression": {
      "type": "PATTERN",
      "value": ".*"
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "\\s"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}